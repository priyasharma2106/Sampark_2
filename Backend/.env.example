# Database
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/sampark_db

# JWT Authentication
SECRET_KEY=replace-with-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Server
HOST=0.0.0.0
PORT=8000

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://your-frontend.vercel.app,https://your-custom-domain.com
